# ── 邮件账号（必填）─────────────────────────────
NEWS_SENDER_EMAIL=your_sender@163.com
NEWS_SENDER_PASSWORD=your_smtp_auth_code
NEWS_RECEIVER_EMAIL=admin@example.com
NEWS_EMAIL_ACCOUNT=your_account@163.com
NEWS_EMAIL_PASSWORD=your_pop3_auth_code
NEWS_ADMIN_EMAIL=admin@example.com

# ── SMTP / POP 服务器 ─────────────────────────
NEWS_SMTP_HOST=smtp.163.com
NEWS_SMTP_PORT=465
NEWS_POP_HOST=pop.163.com
NEWS_POP_PORT=995
